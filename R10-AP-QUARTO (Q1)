# ================================
# DEVICE: R10-AP-QUARTO (Q1)
# RouterOS: 7.20.8
# FUNÇÃO: Access Point / CPE Quarto (Hotspot Cliente)
# VLAN: 200 (Clientes)
# ================================

# === BRIDGE ===
/interface bridge
add name=bridge-cliente vlan-filtering=yes comment="Bridge VLAN 200 (Clientes)"

# === INTERFACES ===
/interface ethernet
set [ find default-name=ether1 ] name=ether1-uplink comment="Uplink (Switch Quartos)"
set [ find default-name=ether2 ] name=ether2-cliente comment="Cliente 1"
set [ find default-name=ether3 ] name=ether3-cliente comment="Cliente 2"
set [ find default-name=ether4 ] name=ether4-cliente comment="Cliente 3"

# === PORTAS ===

# Uplink (TRUNK)
add bridge=bridge-cliente interface=ether1-uplink

# Access (clientes)
add bridge=bridge-cliente interface=ether2-cliente pvid=200
add bridge=bridge-cliente interface=ether3-cliente pvid=200
add bridge=bridge-cliente interface=ether4-cliente pvid=200

# === VLAN ===
/interface bridge vlan
add bridge=bridge-cliente vlan-ids=200 \
    tagged=ether1-uplink \
    untagged=ether2-cliente,ether3-cliente,ether4-cliente

# === ENDEREÇAMENTO (recebe do hotel) ===
/ip dhcp-client
add interface=bridge-cliente comment="Recebe IP da rede VLAN 200"

# === DNS ===
/ip dns
set servers=8.8.8.8 allow-remote-requests=yes

# === HOTSPOT ===
/ip pool
add name=pool-hotspot ranges=10.5.50.2-10.5.50.254

/ip hotspot profile
add name=hotspot-profile hotspot-address=10.5.50.1 dns-name=login.hotel.local

/ip hotspot
add name=hotspot1 interface=bridge-cliente address-pool=pool-hotspot profile=hotspot-profile

/ip hotspot user
add name=quarto1 password=1234 profile=default

# === NAT ===
/ip firewall nat
add action=masquerade chain=srcnat out-interface=bridge-cliente comment="NAT clientes"

# === SISTEMA ===
/system identity
set name=AP-Quarto-01

/tool romon
set enabled=yes
